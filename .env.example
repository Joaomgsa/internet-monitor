# .env.example
# Template seguro para variáveis de ambiente
# NÃO commitar arquivo .env, apenas este .env.example

# ═══════════════════════════════════════════════════════════════
# SPEEDTEST TRACKER - APP_KEY
# ═══════════════════════════════════════════════════════════════
# Gere uma nova chave com: echo "base64:$(openssl rand -base64 32)"
APP_KEY=base64:COLOQUE_SUA_CHAVE_GERADA_AQUI

# ═══════════════════════════════════════════════════════════════
# GRAFANA - CREDENCIAIS
# ═══════════════════════════════════════════════════════════════
# Usuário Admin do Grafana
GRAFANA_USER=admin

# Senha Admin - MUDE ISTO! Use pelo menos 16 caracteres
# Exemplo forte: Gr@f@n@2026!SecurePass123
GRAFANA_PASSWORD=COLOQUE_UMA_SENHA_FORTE_AQUI_MINIMO_16_CARACTERES

# ═══════════════════════════════════════════════════════════════
# INSTRUÇÕES DE SEGURANÇA
# ═══════════════════════════════════════════════════════════════
# 
# 1. NUNCA comitar o arquivo .env com valores reais
# 2. Gerar senhas fortes usando:
#    - openssl rand -base64 32
#    - pwgen -y 20
#    - python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 3. Requisitos para senha segura:
#    - Mínimo 16 caracteres
#    - Maiúsculas e minúsculas
#    - Números e símbolos especiais
#    - Sem palavras dicionário
#
# 4. Após criar .env:
#    chmod 600 .env
#
# 5. Manter apenas .env.example no git
#
